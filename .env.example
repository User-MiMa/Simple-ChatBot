# OpenRouter API base URL (or other model provider)
AI_URL=https://openrouter.ai/api/v1

# OpenRouter API key (obtén una en https://openrouter.ai/keys)
AI_KEY=sk-or-v1-

# Modelo a usar (ej: openai/gpt-4o, openai/gpt-oss-20b:free)
AI_MODEL=openai/gpt-oss-20b:free

# Puerto del servidor (opcional, por defecto 3001)
PORT=3001
